---
interface Props {
  title?: string;
  description?: string;
}
const { title = 'GPT Image 2 プロンプト集（日本語版）', description = 'GPT Image 2 の日本語プロンプトを厳選キュレーション。プロンプトをコピーしてあなたのChatGPTで日本語入りの画像を生成しよう。' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  </head>
  <body>
    <header class="site-header">
      <a href={base} class="brand">
        <span class="brand-logo">🎨</span>
        <span class="brand-text">GPT Image 2 プロンプト集 <span class="brand-jp">日本語版</span></span>
      </a>
      <nav class="site-nav">
        <a href="https://github.com/YouMind-OpenLab/awesome-gpt-image-2" target="_blank" rel="noopener">元データ</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>
        プロンプト・画像データは
        <a href="https://github.com/YouMind-OpenLab/awesome-gpt-image-2" target="_blank" rel="noopener">awesome-gpt-image-2</a>（<a href="https://creativecommons.org/licenses/by/4.0/" target="_blank" rel="noopener">CC BY 4.0</a>）by YouMind OpenLab を元にしています。
      </p>
      <p class="footer-credit">本サイトは非営利の日本語キュレーションです。</p>
    </footer>
    <style is:global>
      :root {
        color-scheme: dark;
        --bg: #0e0e10;
        --bg-elev: #16161a;
        --bg-card: #1a1a1f;
        --border: #26262d;
        --border-strong: #3a3a44;
        --text: #ececef;
        --text-dim: #9a9aa3;
        --text-muted: #6c6c74;
        --accent: #a78bfa;
        --accent-strong: #8b5cf6;
        --gold: #fbbf24;
        --code-bg: #0a0a0c;
        --radius: 12px;
        --radius-lg: 16px;
        --shadow: 0 4px 24px rgba(0, 0, 0, 0.3);
        --max-w: 1200px;
        --header-h: 60px;
        font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', 'Hiragino Sans', 'Noto Sans JP', sans-serif;
      }
      * { box-sizing: border-box; }
      html, body {
        margin: 0;
        padding: 0;
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
      }
      a { color: var(--accent); text-decoration: none; }
      a:hover { color: var(--accent-strong); text-decoration: underline; }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 10;
        height: var(--header-h);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 24px;
        background: rgba(14, 14, 16, 0.85);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border);
      }
      .brand {
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 700;
        font-size: 16px;
        color: var(--text);
        text-decoration: none;
      }
      .brand:hover { text-decoration: none; color: var(--text); }
      .brand-logo { font-size: 22px; }
      .brand-jp {
        font-size: 12px;
        font-weight: 500;
        color: var(--accent);
        background: rgba(167, 139, 250, 0.12);
        padding: 2px 8px;
        border-radius: 4px;
        margin-left: 4px;
      }
      .site-nav a {
        font-size: 14px;
        color: var(--text-dim);
      }
      .site-nav a:hover { color: var(--text); text-decoration: none; }

      main {
        max-width: var(--max-w);
        margin: 0 auto;
        padding: 32px 24px 64px;
      }

      .site-footer {
        max-width: var(--max-w);
        margin: 0 auto;
        padding: 32px 24px 48px;
        border-top: 1px solid var(--border);
        font-size: 13px;
        color: var(--text-muted);
      }
      .site-footer p { margin: 6px 0; }
      .footer-credit { color: var(--text-muted); }

      @media (max-width: 640px) {
        .brand-text { font-size: 14px; }
        .brand-jp { display: none; }
        main { padding: 20px 16px 48px; }
      }
    </style>
  </body>
</html>
