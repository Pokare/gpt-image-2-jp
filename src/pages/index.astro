---
import Layout from '~/layouts/Layout.astro';
import prompts from '~/data/prompts.json';
import meta from '~/data/meta.json';

const base = import.meta.env.BASE_URL;
const stripBase = (p: string) => `${base.replace(/\/$/, '')}${p}`;

const sectionOrder: Record<string, number> = { featured: 0, all: 1, other: 2 };
const sorted = [...prompts].sort((a: any, b: any) => {
  const so = (sectionOrder[a.sourceSection] ?? 99) - (sectionOrder[b.sourceSection] ?? 99);
  if (so !== 0) return so;
  const ss = (b.sourceMeta.stars || 0) - (a.sourceMeta.stars || 0);
  if (ss !== 0) return ss;
  return a.no - b.no;
});

const categories = ['すべて', ...meta.categories];
const lastUpdated = meta.parsedAt
  ? new Date(meta.parsedAt).toLocaleString('ja-JP', { dateStyle: 'long', timeStyle: 'short' })
  : '不明';
---
<Layout>
  <section class="hero">
    <h1 class="hero-title">GPT Image 2 の<br />日本語プロンプト集</h1>
    <p class="hero-sub">
      画像内に日本語テキストが入った作品を作るための、厳選されたプロンプトカタログ。
      コピーしてあなたの ChatGPT に貼り付けるだけで、すぐ使える状態に整えています。
    </p>
    <div class="hero-stats">
      <div class="stat">
        <div class="stat-num">{meta.curatedCount}</div>
        <div class="stat-label">厳選プロンプト</div>
      </div>
      <div class="stat">
        <div class="stat-num">{meta.totalImages}</div>
        <div class="stat-label">サンプル画像</div>
      </div>
      <div class="stat">
        <div class="stat-num">{meta.sources.length}</div>
        <div class="stat-label">ソースリポ</div>
      </div>
    </div>
    <div class="source-stats">
      {meta.sources.map((s: any) => (
        <a href={s.url} target="_blank" rel="noopener" class="source-pill" style={`--c: ${s.color}`}>
          <span class="source-dot"></span>
          <span class="source-name">{s.name}</span>
          <span class="source-count">{s.displayed}件</span>
          <span class="source-stars">★{(s.stars / 1000).toFixed(1)}k</span>
        </a>
      ))}
    </div>
    <p class="hero-meta">最終同期: {lastUpdated}</p>
  </section>

  <section class="controls">
    <input
      type="search"
      id="search"
      placeholder="🔍 タイトル・説明・プロンプト本文・カテゴリで検索..."
      autocomplete="off"
    />

    <div class="filter-group">
      <span class="filter-label">ソース</span>
      <div class="filters" id="source-filters">
        <button class="chip chip-source active" data-src="すべて" type="button">すべて</button>
        {meta.sources.map((s: any) => (
          <button class="chip chip-source" data-src={s.id} type="button" style={`--c: ${s.color}`}>
            <span class="source-dot"></span>{s.name}
          </button>
        ))}
      </div>
    </div>

    <div class="filter-group">
      <span class="filter-label">カテゴリ</span>
      <div class="filters" id="cat-filters">
        {categories.map((c) => (
          <button class={`chip ${c === 'すべて' ? 'active' : ''}`} data-cat={c} type="button">
            {c}
          </button>
        ))}
      </div>
    </div>
  </section>

  <section class="grid" id="grid">
    {sorted.map((p: any) => (
      <a class="card"
         href={stripBase(`/p/${p.id}/`)}
         data-cat={p.category || ''}
         data-src={p.sourceMeta.id}
         data-search={`${p.title} ${p.titleOriginal || ''} ${p.description} ${p.prompt} ${p.category || ''}`.toLowerCase()}>
        <div class="card-img-wrap">
          {p.images[0] ? (
            <img src={p.images[0].src} alt={p.images[0].alt} loading="lazy" />
          ) : (
            <div class="card-img-placeholder">画像なし</div>
          )}
          {p.isFeatured && <span class="badge badge-featured">⭐ 注目</span>}
          {p.images.length > 1 && <span class="badge badge-count">+{p.images.length - 1}</span>}
          <span class="badge badge-source" style={`background: ${p.sourceMeta.color}`}>
            {p.sourceMeta.name}
          </span>
        </div>
        <div class="card-body">
          {p.category && <span class="card-cat">{p.category}</span>}
          <h3 class="card-title">{p.title}</h3>
          {p.description && <p class="card-desc">{p.description}</p>}
        </div>
      </a>
    ))}
  </section>

  <p class="empty-state" id="empty" hidden>
    該当するプロンプトが見つかりませんでした。フィルターか検索ワードを変えてみてください。
  </p>
</Layout>

<script>
  const search = document.getElementById('search') as HTMLInputElement;
  const sourceFilters = document.getElementById('source-filters') as HTMLDivElement;
  const catFilters = document.getElementById('cat-filters') as HTMLDivElement;
  const grid = document.getElementById('grid') as HTMLElement;
  const empty = document.getElementById('empty') as HTMLElement;
  const cards = Array.from(grid.querySelectorAll<HTMLElement>('.card'));

  let activeSrc = 'すべて';
  let activeCat = 'すべて';
  let query = '';

  function bindFilter(container: HTMLElement, key: string, setter: (v: string) => void) {
    container.addEventListener('click', (e) => {
      const target = (e.target as HTMLElement).closest('.chip') as HTMLElement | null;
      if (!target) return;
      setter(target.dataset[key] || 'すべて');
      container.querySelectorAll('.chip').forEach((c) => c.classList.remove('active'));
      target.classList.add('active');
      apply();
    });
  }

  bindFilter(sourceFilters, 'src', (v) => { activeSrc = v; });
  bindFilter(catFilters, 'cat', (v) => { activeCat = v; });

  search.addEventListener('input', () => {
    query = search.value.trim().toLowerCase();
    apply();
  });

  function apply() {
    let shown = 0;
    cards.forEach((card) => {
      const cat = card.dataset.cat || '';
      const src = card.dataset.src || '';
      const text = card.dataset.search || '';
      const matchSrc = activeSrc === 'すべて' || src === activeSrc;
      const matchCat = activeCat === 'すべて' || cat === activeCat;
      const matchQuery = query === '' || text.includes(query);
      const visible = matchSrc && matchCat && matchQuery;
      card.style.display = visible ? '' : 'none';
      if (visible) shown++;
    });
    empty.hidden = shown > 0;
  }
</script>

<style>
  .hero {
    text-align: center;
    padding: 32px 0 40px;
  }
  .hero-title {
    font-size: clamp(28px, 5vw, 48px);
    line-height: 1.2;
    margin: 0 0 16px;
    font-weight: 800;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, #fff 0%, #a78bfa 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .hero-sub {
    font-size: 15px;
    line-height: 1.7;
    color: var(--text-dim);
    max-width: 580px;
    margin: 0 auto 28px;
  }
  .hero-stats {
    display: flex;
    justify-content: center;
    gap: 24px;
    margin: 28px 0 16px;
    flex-wrap: wrap;
  }
  .stat {
    text-align: center;
    padding: 12px 18px;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    min-width: 100px;
  }
  .stat-num {
    font-size: 26px;
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
  }
  .stat-label {
    font-size: 11px;
    color: var(--text-dim);
    margin-top: 6px;
    letter-spacing: 0.05em;
  }
  .source-stats {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 8px;
    margin: 8px auto 12px;
    max-width: 720px;
  }
  .source-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 999px;
    font-size: 12px;
    color: var(--text-dim);
    text-decoration: none;
    transition: all 0.15s;
  }
  .source-pill:hover {
    border-color: var(--c);
    color: var(--text);
    text-decoration: none;
  }
  .source-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--c, var(--accent));
    flex-shrink: 0;
  }
  .source-name { font-weight: 600; color: var(--text); }
  .source-count { color: var(--text-dim); }
  .source-stars { color: var(--gold); font-size: 11px; }
  .hero-meta {
    font-size: 12px;
    color: var(--text-muted);
    margin-top: 4px;
  }

  .controls {
    margin: 32px 0 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  #search {
    width: 100%;
    padding: 14px 18px;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--text);
    font-size: 15px;
    font-family: inherit;
    transition: border-color 0.15s;
  }
  #search:focus { outline: none; border-color: var(--accent); }
  .filter-group {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }
  .filter-label {
    flex-shrink: 0;
    padding: 8px 0;
    font-size: 11px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
    min-width: 56px;
  }
  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    flex: 1;
  }
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--text-dim);
    font-size: 13px;
    font-family: inherit;
    cursor: pointer;
    transition: all 0.15s;
  }
  .chip:hover { color: var(--text); border-color: var(--border-strong); }
  .chip.active {
    background: var(--accent);
    border-color: var(--accent);
    color: #1a1a1f;
    font-weight: 600;
  }
  .chip-source.active {
    background: var(--c, var(--accent));
    border-color: var(--c, var(--accent));
  }
  .chip-source.active .source-dot { background: rgba(0,0,0,0.4); }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
  }
  .card {
    display: flex;
    flex-direction: column;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    color: var(--text);
    transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
    text-decoration: none !important;
  }
  .card:hover {
    transform: translateY(-3px);
    border-color: var(--accent);
    box-shadow: var(--shadow);
  }
  .card-img-wrap {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--bg-elev);
  }
  .card-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .card-img-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    color: var(--text-muted);
    font-size: 13px;
  }
  .badge {
    position: absolute;
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 600;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .badge-featured {
    top: 10px;
    left: 10px;
    background: rgba(251, 191, 36, 0.95);
    color: #1a1a1f;
  }
  .badge-count {
    top: 10px;
    right: 10px;
    background: rgba(0, 0, 0, 0.6);
    color: white;
  }
  .badge-source {
    bottom: 10px;
    left: 10px;
    color: #0e0e10;
    font-size: 10px;
    padding: 3px 8px;
    background: rgba(0,0,0,0.7);
    color: white;
  }
  .card-body {
    padding: 14px 16px 18px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
  }
  .card-cat {
    font-size: 11px;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
  }
  .card-title {
    font-size: 15px;
    line-height: 1.4;
    margin: 0;
    color: var(--text);
    font-weight: 600;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-desc {
    font-size: 12.5px;
    line-height: 1.55;
    color: var(--text-dim);
    margin: 4px 0 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .empty-state {
    text-align: center;
    color: var(--text-muted);
    padding: 48px 0;
    font-size: 14px;
  }

  @media (max-width: 640px) {
    .filter-group { flex-direction: column; gap: 6px; }
    .filter-label { padding: 0; }
  }
</style>
